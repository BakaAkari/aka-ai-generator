{
  "name": "koishi-plugin-aka-ai-generator",
  "description": "自用AI生成插件(GPTGod & Yunwu)",
  "version": "0.12.12",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsc --watch",
    "test:video-orchestrator": "npx -y tsx ./src/orchestrators/VideoOrchestrator.spec.ts",
    "test:utils": "npx -y tsx ./src/providers/utils.spec.ts",
    "test:user-manager": "npx -y tsx ./src/services/UserManager.spec.ts",
    "test:input": "npx -y tsx ./src/utils/input.spec.ts",
    "test": "npm run test:video-orchestrator && npm run test:utils && npm run test:user-manager && npm run test:input"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "koishi": "^4.18.9"
  },
  "dependencies": {
    "jimp": "^0.22.10"
  }
}
